<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:padding="6dp">

    <Button
        android:id="@+id/buttonAddCity"
        android:text="Add City"
        android:textSize="20sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="10dp"/>

    <TextView
        android:id="@+id/textDeleteInstruction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="(Long press a city to delete)"
        android:textSize="14sp"
        android:textStyle="italic"
        android:textColor="@android:color/darker_gray"
        app:layout_constraintBottom_toBottomOf="@+id/buttonAddCity"
        app:layout_constraintStart_toEndOf="@+id/buttonAddCity"
        app:layout_constraintTop_toTopOf="@+id/buttonAddCity"
        android:layout_marginStart="15dp" />

    <ListView
        android:id="@+id/listviewCities"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/buttonAddCity"
        android:layout_marginTop="10dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>